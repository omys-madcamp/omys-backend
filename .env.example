ENVIRONMENT=development
DATABASE_URL=sqlite:///./omys.db
CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# mock | kakao | google
PLACES_PROVIDER=mock
GOOGLE_PLACES_API_KEY=
KAKAO_REST_API_KEY=
# Tmap(SK Open API) 보행자 길찾기. 콘솔에서 앱에 "경로안내" 상품을 연결해야 동작함.
TMAP_API_KEY=

# /api/admin/stats 인증용. 배포 전 반드시 변경할 것.
ADMIN_API_KEY=change-me-before-production

MIN_STAY_MINUTES=60
SEARCH_CACHE_SECONDS=180
